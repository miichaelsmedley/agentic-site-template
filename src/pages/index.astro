---
import { getCollection } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';
import StructuredData from '../components/seo/StructuredData.astro';
import TinaVisualEditing from '../components/tina/TinaVisualEditing.astro';
import HomePosterWallLanding from '../components/home/HomePosterWallLanding.astro';
import siteConfig from '../config/site';

const homeEntry = (await getCollection('home'))[0];
const homeHeroImage =
  homeEntry?.data.hero.slides?.[0]?.background_image ||
  homeEntry?.data.hero.slides?.[0]?.image ||
  siteConfig.seo.defaultOgImage;

const personData = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: siteConfig.name,
  description: siteConfig.description,
  url: siteConfig.url,
  image: new URL(siteConfig.seo.defaultOgImage, siteConfig.url).toString(),
  email: siteConfig.social.email,
  jobTitle: 'Technology, Growth and Delivery Leader',
  worksFor: {
    '@type': 'Organization',
    name: siteConfig.name,
  },
};
---

<PageLayout
  title={homeEntry?.data.seo_title || 'Home'}
  description={homeEntry?.data.seo_description || siteConfig.description}
  ogImage={homeHeroImage}
  theme="dark"
  bodyClass="home-dark-page"
>
  <TinaVisualEditing collection="home" relativePath="index.md" />
  <StructuredData data={personData} />
  <HomePosterWallLanding homeEntry={homeEntry} />
</PageLayout>
