{
  "name": "agentic-site-template",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "description": "A transportable Astro, TinaCMS, GitHub and Cloudflare website template for novice agentic coders.",
  "license": "MIT",
  "author": "Michael Smedley",
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10"
  },
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "configure": "node scripts/configure-site.mjs",
    "doctor": "node scripts/doctor.mjs",
    "dev": "TINA_PUBLIC_IS_LOCAL=true tinacms dev --datalayer-port 9010 --port 4010 -c \"astro dev --port 4330 --host 0.0.0.0\"",
    "dev:astro": "astro dev --port 4330 --host 0.0.0.0",
    "build:cms": "TINA_PUBLIC_IS_LOCAL=true tinacms build --local --skip-cloud-checks --datalayer-port 9110 --port 4110",
    "build": "npm run build:cms && astro build",
    "preview": "astro preview --port 4331 --host 0.0.0.0",
    "deploy": "npm run build && wrangler deploy",
    "cf:login": "wrangler login",
    "cf:whoami": "wrangler whoami",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "@bands/ui": "file:./packages/ui",
    "astro": "^6.2.1",
    "tinacms": "^3.7.5"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.4",
    "@tinacms/cli": "^2.2.5",
    "vite": "^7",
    "wrangler": "^4.0.0"
  }
}
